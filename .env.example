# ============================================================
# Agente Easypanel (Claude)
# ============================================================

# Chave da API da Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# URL do Easypanel
# - Local/dev pela internet: http://2.24.110.21:3000
# - Dentro do Easypanel (mesma instância): http://easypanel:3000
EASYPANEL_URL=http://easypanel:3000

# Token permanente da API do Easypanel
EASYPANEL_TOKEN=cole-aqui-o-token

# (opcional) Modelo do Claude
ANTHROPIC_MODEL=claude-sonnet-4-5

# ============================================================
# Voice Agent (Whisper + GPT + Evolution API)
# ============================================================

OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini
WHISPER_MODEL=whisper-1

# Evolution API — externamente: https://blink-evolution-api.6prkfn.easypanel.host
# Internamente (dentro do Easypanel): http://blink_evolution-api:8080
EVOLUTION_BASE_URL=http://blink_evolution-api:8080
EVOLUTION_API_KEY=429683C4C977415CAAFCCE10F7D57E11
EVOLUTION_INSTANCE=blink-0710

# Idioma de resposta e tamanho máximo
RESPONSE_LANGUAGE=pt
MAX_RESPONSE_CHARS=1200

# (opcional) Segredo do webhook — se setado, exige header X-Webhook-Secret
WEBHOOK_SECRET=

# ============================================================
# Kommo CRM (auto-preenchimento de campos do lead)
# ============================================================
# Subdomínio da conta Kommo (ex: para univeja.kommo.com → KOMMO_SUBDOMAIN=univeja)
KOMMO_SUBDOMAIN=univeja
# Long-Lived JWT criado em Configurações → Integrações
KOMMO_TOKEN=

# ============================================================
# Redis (persistência de histórico de conversa + dedup)
# ============================================================
# Sem isto, o histórico vive em RAM e é perdido a cada restart.
REDIS_URL=

# ============================================================
# Medware (sistema de agenda da clínica)
# ============================================================
MEDWARE_USER=agendamentoweb
MEDWARE_PASSWORD=

# ============================================================
# Reativação de leads frios (motor — DESLIGADO por padrão)
# ============================================================
# Duas travas de segurança:
#  - REACTIVATION_ENABLED=false  → o motor nem roda.
#  - REACTIVATION_DRY_RUN=true   → roda e monta a mensagem, mas NÃO envia.
# Mensagem real só sai com ENABLED=true E DRY_RUN=false ao mesmo tempo.
REACTIVATION_ENABLED=false
REACTIVATION_DRY_RUN=true
# Ritmo: teto diário, intervalo mínimo (min) e janela de horário (BRT, seg-sex)
REACTIVATION_DAILY_CAP=30
REACTIVATION_MIN_INTERVAL_MIN=8
REACTIVATION_HOUR_START=8
REACTIVATION_HOUR_END=18
# Funil e etapas frias (IDs do Kommo). Padrão: funil ATENDE.
REACTIVATION_PIPELINE_ID=8601819
REACTIVATION_COLD_STATUS_IDS=96441724,101508307,102560495,106184631,106184983
REACTIVATION_TARGET_STATUS_ID=102560495
# (opcional) Incoming Webhook do Slack para registrar cada reativação num canal
SLACK_WEBHOOK_URL=
